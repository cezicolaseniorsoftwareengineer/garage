### Garage sample env
DATABASE_URL=
FALLBACK_DATABASE_URL=
ALLOWED_ORIGINS=

# Payment provider (Asaas)
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_SECRET=
ASAAS_SIGNATURE_HEADER=X-Asaas-Signature
ENABLE_ASAAS_WEBHOOK=false

# Email / Resend
RESEND_API_KEY=
# GARAGE Environment Configuration (sample)
# Copy this file to `.env` and fill values locally. NEVER commit `.env`.

JWT_SECRET_KEY=<REPLACE_WITH_RANDOM_32+_CHAR_SECRET>
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<CHANGE_ME>
ALLOWED_ORIGINS=http://localhost:3000
ENV=development

# AI / third-party API keys (set only in local .env or secret manager)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GROQ_API_KEY=

# Asaas (payments)
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3

# Email (SMTP) or Resend — set one provider only
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
RESEND_API_KEY=

JAVA_RUNNER_URL=http://localhost:8080
JAVA_RUNNER_SECRET=

# Dev flags
DEBUG=false
PORT=8000
