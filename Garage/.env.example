# Example env variables for GARAGE
# Copy to .env and fill secrets for production

JWT_SECRET_KEY=changeme_replace_with_strong_random
# Neon PostgreSQL URL format - obtain from Neon dashboard
DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require
ADMIN_EMAIL=admin@garage.local
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENV=development

# Study Chat provider (server-side only; never expose in frontend)
# Anthropic Claude — prioridade quando ANTHROPIC_API_KEY estiver preenchida
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODELS=claude-sonnet-4-6,claude-opus-4-6,claude-sonnet-4-5

# OpenAI — fallback quando Anthropic nao estiver configurado
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5
OPENAI_FALLBACK_MODELS=gpt-5,gpt-4.1,gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=90
OPENAI_REQUEST_RETRIES=2
OPENAI_MAX_OUTPUT_TOKENS=700

# Groq (free tier fallback)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenRouter ────────────────────────────────────────────────────────────
# Chave 1: Garage IA (chat de estudos — study_routes.py)
# Usada pelo assistente de aprendizado dentro do jogo.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=google/gemini-flash-1.5
OPENROUTER_TIMEOUT=5

# Chave 2: IDE Java com esteróides (ai_validator_routes.py) — ISOLADA
# Chave EXCLUSIVA para o compilador/validador Java 17 com IA.
# Se não configurada, o sistema usa OPENROUTER_API_KEY como fallback.
# Crie uma nova chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY_IDE=sk-or-v1-yyyyyyyyyyyyyyyyyyyyyy
OPENROUTER_IDE_MODEL=google/gemini-flash-1.5
OPENROUTER_IDE_TIMEOUT=5
# ───────────────────────────────────────────────────────────────────────────

# Gemini (fallback opcional)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash

# ── Pagamentos Asaas (PIX dinâmico) ────────────────────────────────────────
# Obtenha sua chave em: app.asaas.com → Configurações → Integrações → Chave de API
# SANDBOX: $aact_hmlg_xxxx  |  PRODUÇÃO: $aact_prod_xxxx
ASAAS_API_KEY=$aact_prod_xxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox: https://api-sandbox.asaas.com/v3 | Produção: https://api.asaas.com/v3
ASAAS_BASE_URL=https://api.asaas.com/v3
# Preços em reais (use 5.00 para testes E2E, restaurar para 97/997 em produção)
PRICE_MONTHLY=97.00
PRICE_ANNUAL=997.00
# Webhook: cadastrar em app.asaas.com → Integrações → Webhooks
# URL: https://SEU_DOMINIO/api/payments/webhook/asaas
# Eventos: PAYMENT_CONFIRMED, PAYMENT_RECEIVED
